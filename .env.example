# Django
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=change-me-to-a-random-secret-key-min-50-chars
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (local PostgreSQL via Homebrew)
# Setup: brew install postgresql@16 && createdb smile_memory
DATABASE_URL=postgres://travel:travel_dev@localhost:5432/smile_memory

# Redis (local via Homebrew)
# Setup: brew install redis && brew services start redis
REDIS_URL=redis://localhost:6379/0

# Email — Brevo REST API (production transactional email)
BREVO_API_KEY=
DEFAULT_FROM_EMAIL=Smile Memory <noreply@smilememorytravel.com>
ADMIN_EMAIL=baifern@smilememorytravel.com

# Admin password (synced by ensure_adminpassword management command on deploy)
ADMIN_PASSWORD=

# Wholesaler API credentials (production only — Railway env vars)
ZEGO_USERNAME=
ZEGO_PASSWORD=
GO365_API_KEY=
GS25_USERNAME=
GS25_PASSWORD=

# LINE (contact widget)
LINE_AT_ID=@smilememory

# Sentry (production error monitoring)
SENTRY_DSN=

# Site URL
SITE_URL=http://localhost:8000
